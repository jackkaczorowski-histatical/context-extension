{
  "manifest_version": 3,
  "name": "Context",
  "version": "1.0.0",
  "description": "Real-time audio context extraction from browser tabs",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
