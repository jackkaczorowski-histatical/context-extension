{
  "manifest_version": 3,
  "name": "Context",
  "version": "1.0.0",
  "description": "Real-time audio context extraction from browser tabs",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://context-extension-zv8d.vercel.app/*",
    "wss://api.deepgram.com/*",
    "*://*.youtube.com/*",
    "*://*.spotify.com/*",
    "*://*.udemy.com/*",
    "*://*.soundcloud.com/*",
    "*://*.podcasts.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {},
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle Context Listener sidebar"
    }
  }
}
