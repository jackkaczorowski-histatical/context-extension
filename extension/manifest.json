{
  "manifest_version": 3,
  "name": "Context",
  "privacy_policy": "https://context-extension-zv8d.vercel.app/privacy",
  "version": "1.0.0",
  "description": "Real-time audio context extraction from browser tabs",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "storage",
    "offscreen",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://context-extension-zv8d.vercel.app/*",
    "wss://api.deepgram.com/*",
    "https://www.googleapis.com/*",
    "*://*.youtube.com/*",
    "*://*.spotify.com/*",
    "*://*.udemy.com/*",
    "*://*.soundcloud.com/*",
    "*://*.podcasts.google.com/*"
  ],
  "oauth2": {
    "client_id": "431347797056-i4th6beimiv4ask3dtm8l4nlhceua8ba.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.spotify.com/*", "*://*.udemy.com/*", "*://*.soundcloud.com/*", "*://*.podcasts.google.com/*", "*://*.netflix.com/*", "*://*.twitch.tv/*", "*://*.coursera.org/*", "*://*.khanacademy.org/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+X"
      },
      "description": "Toggle Context Listener sidebar"
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle Context Listener sidebar"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
